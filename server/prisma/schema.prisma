datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int       @id @default(autoincrement())
  alias       String    @unique
  name        String?
  description String?
  rollNumber  String    @unique
  password    String
  avatar      String?
  xp          Int       @default(0)
  solved      Int       @default(0)
  posts       Post[]
  comments    Comment[]
}

model Wing {
  id      String  @id
  name    String
  color   String
  iconId  String?
}

model Post {
  id           Int       @id @default(autoincrement())
  author_id    Int
  author       User      @relation(fields: [author_id], references: [id])
  is_anonymous Boolean   @default(false)
  title        String
  text_content String
  image_url    String?
  wing_id      String
  is_solved    Boolean   @default(false)
  upvotes      Int       @default(0)
  upvotedBy    String    @default("[]")
  created_at   DateTime  @default(now())
  comments     Comment[]
}

model Comment {
  id                Int       @id @default(autoincrement())
  post_id           Int
  post              Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author_id         Int
  author            User      @relation(fields: [author_id], references: [id])
  is_anonymous      Boolean   @default(false)
  text_content      String
  parent_comment_id Int?
  parent_comment    Comment?  @relation("Thread", fields: [parent_comment_id], references: [id], onDelete: Cascade)
  child_comments    Comment[] @relation("Thread")
  created_at        DateTime  @default(now())
}
